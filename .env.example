# Copy this file to .env and fill in real values before running the backend.
# Generate JWT_SECRET with: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"

PORT=4000
JWT_SECRET=replace_with_64_byte_random_hex
JWT_EXPIRE=7d
COOKIE_EXPIRE=5
CLIENT_ORIGIN=http://localhost:3002
# MongoDB credentials — must match MONGO_ROOT_USER / MONGO_ROOT_PASSWORD in .env (used by docker compose)
MONGO_URI=mongodb://MONGO_ROOT_USER:MONGO_ROOT_PASSWORD@localhost:27017/web3games?authSource=admin

# Optional — leave as placeholder if not using SendGrid
SENDGRID_API_KEY=SG.placeholder
SENDGRID_MAIL=noreply@example.com
SENDGRID_RESET_TEMPLATEID=d-placeholder
SENDGRID_ORDER_TEMPLATEID=d-placeholder

# Optional — leave as placeholder if not using Cloudinary (avatar uploads will use URL fallback)
CLOUDINARY_NAME=placeholder
CLOUDINARY_API_KEY=placeholder
CLOUDINARY_API_SECRET=placeholder

# Optional — leave as placeholder if not using Stripe
STRIPE_API_KEY=placeholder
STRIPE_SECRET_KEY=placeholder

NODE_ENV=development

# MongoDB root credentials for docker compose (also referenced in MONGO_URI above).
# Copy these into .env at the project root and choose strong values.
MONGO_ROOT_USER=devuser
MONGO_ROOT_PASSWORD=replace_with_strong_password

# Set to the number of trusted reverse proxies in front of the app (e.g. 1 for Vercel/nginx).
# 0 = direct connection; rate limiting uses the TCP peer IP.
# N = rate limiting reads X-Forwarded-For N hops from the right.
TRUSTED_PROXY_COUNT=0
